            "readonly": false,
            "desc": "Mint a consent ASA and store the record in box storage.\nThe caller (Txn.sender) becomes the token holder and logical owner of the consent. The application holds manager/freeze/clawback so it can freeze the token upon revocation.\nReturns the newly created asset ID.",
            "events": [],
            "recommendations": {}
        },
        {
            "name": "revoke_consent",
            "args": [
                {
                    "type": "uint64",
                    "name": "asset_id"
                }
            ],
            "returns": {
                "type": "void"
            },
            "actions": {
                "create": [],
                "call": [
                    "NoOp"
                ]
            },
            "readonly": false,
            "desc": "Freeze the consent ASA to represent on-chain revocation.\nOnly the original owner of the consent may call this.",
            "events": [],
            "recommendations": {}
        },
        {
            "name": "is_consent_valid",
            "args": [
                {
                    "type": "uint64",
                    "name": "asset_id"
                },
                {
                    "type": "address",
                    "name": "requester"
                }
            ],
            "returns": {
                "type": "bool"
            },
            "actions": {
                "create": [],
                "call": [
                    "NoOp"
                ]
            },
            "readonly": true,
            "desc": "Read-only verifier: returns True if consent is active and not expired.\nChecks: 1. A consent record exists for this asset_id. 2. The requester matches the record. 3. The expiry timestamp has not passed. 4. The ASA is not frozen (i.e., not revoked).",
            "events": [],
            "recommendations": {}
        }
    ],
    "arcs": [
        22,
        28
    ],
    "desc": "\n    ConsentLedger - Decentralized consent management on Algorand.\n\n    Consent is minted as an ASA held by the user. Revoking consent\n    freezes that ASA on-chain. is_consent_valid can be called by any\n    third-party verifier without touching state.\n    ",
