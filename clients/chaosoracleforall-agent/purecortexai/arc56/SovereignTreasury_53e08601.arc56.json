            "readonly": false,
            "desc": "Burn CORTEX tokens by sending them to the Algorand zero address.\nThe caller must send CORTEX tokens to this contract in the same group transaction. The contract then forwards them to the zero address, permanently removing them from circulation.",
            "events": [],
            "recommendations": {}
