{
  "arcs": [4, 56],
  "name": "CadenciaEscrow",
  "desc": "Cadencia B2B Trade Escrow Contract. ARC-4 + ARC-56 compliant smart contract for MSME trade settlement on Algorand.",
  "methods": [
    {
      "name": "initialize",
      "desc": "Initialize escrow on contract creation. Creator only. Sets status=DEPLOYED(0), frozen=0.",
      "readonly": false,
      "args": [
        {
          "name": "buyer",
          "type": "address",
          "desc": "Algorand address of buyer enterprise"
        },
        {
          "name": "seller",
          "type": "address",
          "desc": "Algorand address of seller enterprise"
        },
        {
          "name": "amount",
          "type": "uint64",
          "desc": "Escrow amount in microALGO"
        },
        {
          "name": "session_id",
          "type": "string",
          "desc": "Cadencia negotiation session UUID (UTF-8)"
        }
      ],
      "returns": {
        "type": "void"
      },
      "events": [],
      "actions": {
        "create": ["call"],
        "call": []
      }
    },
    {
      "name": "fund",
      "desc": "Fund the escrow. Must be atomic group: [PaymentTxn, AppCallTxn]. payment.amount must equal escrow amount (SRS-SC-002).",
      "readonly": false,
      "args": [
        {
          "name": "payment",
          "type": "pay",
          "desc": "Payment transaction funding the escrow. Receiver must be contract address."
        }
      ],
      "returns": {
        "type": "void"
      },
      "events": [],
      "actions": {
        "create": [],
        "call": ["call"]
      }
    },
    {
      "name": "release",
      "desc": "Release funds to seller. Creator only. Anchors Merkle root in inner transaction note field.",
      "readonly": false,
      "args": [
        {
          "name": "merkle_root",
          "type": "string",
          "desc": "SHA-256 Merkle root of all session audit events (hex-encoded)"
        }
      ],
      "returns": {
        "type": "void"
      },
      "events": [],
      "actions": {
        "create": [],
        "call": ["call"]
      }
    },
    {
      "name": "refund",
      "desc": "Refund buyer. Creator only. Used when trade fails or dispute resolved in buyer favour.",
      "readonly": false,
      "args": [
        {
          "name": "reason",
          "type": "string",
          "desc": "Refund reason (stored in inner transaction note)"
        }
      ],
      "returns": {
        "type": "void"
      },
      "events": [],
      "actions": {
        "create": [],
        "call": ["call"]
      }
    },
    {
      "name": "freeze",
      "desc": "Freeze escrow to halt all state transitions. Access: buyer, seller, or creator.",
      "readonly": false,
      "args": [],
      "returns": {
        "type": "void"
      },
      "events": [],
      "actions": {
        "create": [],
        "call": ["call"]
      }
    },
    {
      "name": "unfreeze",
      "desc": "Unfreeze escrow after dispute resolution. Creator only (SRS-SC-004).",
      "readonly": false,
      "args": [],
      "returns": {
        "type": "void"
      },
      "events": [],
      "actions": {
        "create": [],
        "call": ["call"]
      }
    }
  ],
  "state": {
    "schema": {
      "global": {
        "ints": 3,
