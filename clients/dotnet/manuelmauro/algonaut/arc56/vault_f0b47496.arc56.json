{
  "arcs": [56],
  "name": "Vault",
  "desc": "An ARC-56 contract exercising named-struct arguments",
  "structs": {
    "Pair": [
      { "name": "first", "type": "uint64" },
      { "name": "second", "type": "uint64" }
    ],
    "Holder": [
      { "name": "owner", "type": "address" },
      { "name": "amount", "type": "uint64" }
    ],
    "Wrapper": [
      { "name": "inner", "type": "Pair" },
      { "name": "label", "type": "string" }
    ]
  },
  "methods": [
    {
      "name": "store",
      "desc": "Store a pair",
      "args": [{ "name": "p", "type": "(uint64,uint64)", "struct": "Pair" }],
      "returns": { "type": "void" }
    },
    {
      "name": "store_wrapped",
      "args": [
        {
          "name": "w",
          "type": "((uint64,uint64),string)",
          "struct": "Wrapper"
        }
      ],
      "returns": { "type": "void" }
    },
    {
      "name": "get_pair",
      "args": [],
      "returns": { "type": "(uint64,uint64)", "struct": "Pair" }
    },
    {
      "name": "scale",
      "desc": "Mix a struct argument with a scalar",
      "args": [
        { "name": "p", "type": "(uint64,uint64)", "struct": "Pair" },
        { "name": "factor", "type": "uint64" }
      ],
      "returns": { "type": "uint64" }
    },
    {
      "name": "incr",
      "desc": "Increment by a step that defaults to the literal 1",
      "args": [
        {
          "name": "step",
          "type": "uint64",
          "defaultValue": { "source": "literal", "data": "AAAAAAAAAAE=", "type": "uint64" }
        }
      ],
      "returns": { "type": "uint64" }
    },
    {
      "name": "enroll",
      "desc": "Opt the caller into the app",
      "args": [],
      "returns": { "type": "void" },
      "actions": { "create": [], "call": ["NoOp", "OptIn"] }
    },
    {
      "name": "sum",
      "desc": "Sum a dynamic uint64 array (array-argument round trip)",
      "args": [{ "name": "xs", "type": "uint64[]" }],
      "returns": { "type": "uint64" }
    },
    {
      "name": "sum3",
      "desc": "Sum a static uint64[3] array",
      "args": [{ "name": "xs", "type": "uint64[3]" }],
      "returns": { "type": "uint64" }
    }
    ,{
      "name": "who",
      "desc": "Echo a referenced account (reference-argument round trip)",
      "args": [{ "name": "acct", "type": "account" }],
      "returns": { "type": "address" }
    }
    ,{
      "name": "box_put",
      "desc": "Write a uint64 into a box (box-reference round trip)",
      "args": [{ "name": "name", "type": "string" }, { "name": "value", "type": "uint64" }],
      "returns": { "type": "void" }
    },
    {
      "name": "box_get",
      "desc": "Read a uint64 from a box",
      "args": [{ "name": "name", "type": "string" }],
      "returns": { "type": "uint64" }
    }
    ,{
      "name": "deposit",
      "desc": "Verify a grouped payment (transaction-argument round trip)",
      "args": [{ "name": "payment", "type": "pay" }, { "name": "expected", "type": "uint64" }],
      "returns": { "type": "void" }
    }
    ,{
      "name": "add_pair",
      "desc": "Sum an anonymous (uint64,uint64) tuple argument",
      "args": [{ "name": "p", "type": "(uint64,uint64)" }],
      "returns": { "type": "uint64" }
    }
    ,{
      "name": "price_raw",
      "desc": "Return the raw, unscaled integer of a ufixed64x2 argument",
      "args": [{ "name": "p", "type": "ufixed64x2" }],
      "returns": { "type": "uint64" }
    }
  ],
  "events": [
    {
      "name": "Counted",
      "desc": "Emitted when the counter changes",
      "args": [{ "name": "total", "type": "uint64" }]
    }
  ],
  "state": {
    "schema": {
      "global": { "ints": 1, "bytes": 1 },
      "local": { "ints": 1, "bytes": 0 }
    },
    "keys": {
      "global": {
        "total": { "keyType": "AVMString", "valueType": "AVMUint64", "key": "dG90YWw=" },
        "owner": { "keyType": "AVMString", "valueType": "address", "key": "b3duZXI=" }
      },
      "local": {
        "seen": { "keyType": "AVMString", "valueType": "AVMUint64", "key": "c2Vlbg==" }
      },
      "box": {}
    },
    "maps": {
      "global": {},
      "local": {},
      "box": {
        "boxes": { "keyType": "AVMString", "valueType": "AVMUint64" }
      }
    }
  },
