            "readonly": false,
            "desc": "Verify and atomically consume a payment ref. Intended for inner app-calls\nfrom downstream dApps. Four guards in order:\n  1. Proof-only \u2014 zero userAddress attestations are never consumable.\n  2. Identity   \u2014 caller must be the attested userAddress.\n  3. Replay     \u2014 ref must not already be spent.\n  4. Intent lock \u2014 sha256(currentCalldata) must equal the stored contextHash.",
            "events": [],
            "recommendations": {}
        }
